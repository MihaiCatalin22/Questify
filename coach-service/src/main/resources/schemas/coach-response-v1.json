{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "suggestions",
    "reflection",
    "nudge"
  ],
  "properties": {
    "suggestions": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["title", "estimatedMinutes", "difficulty", "reason"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "estimatedMinutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 240
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "additionalProperties": false
      }
    },
    "reflection": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "nudge": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    }
  },
  "additionalProperties": false
}
